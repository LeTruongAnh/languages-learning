# Replace yourdomain.com with the real domain. Caddy handles TLS automatically.
yourdomain.com {
  encode gzip zstd

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }

  # NOTE: dung `handle` (KHONG dung handle_path) vi backend dang ky route
  # kem prefix /api — strip prefix se lam 404 toan bo API.
  handle /api/* {
    reverse_proxy api:8000
  }

  handle {
    root * /srv/web
    try_files {path} /index.html
    file_server
  }
}
