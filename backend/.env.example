# Copy to .env and fill in real values. NEVER commit .env.

# App
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://vocab:CHANGE_ME@localhost:5432/vocab_app
POSTGRES_PASSWORD=CHANGE_ME

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_64_BYTES_RANDOM
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# CORS (comma-separated; only needed for web companion)
CORS_ORIGINS=http://localhost:5173
